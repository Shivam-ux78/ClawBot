TARGET_BUDGET=100
MAX_BUDGET=150

# ─── Safety / Rate Limiting ──────────────────────────────────────
DM_DAILY_LIMIT=30
DM_DELAY_MIN_SEC=60
DM_DELAY_MAX_SEC=90

# ─── Redis & Database ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres.atsepfvcsdzjsqjuhbym:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

