# ─── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Instagram ──────────────────────────────────────────────────
# Set to false to send real DMs
INSTAGRAM_STUB_MODE=true
# Credentials for instagram-private-api
IG_USERNAME=
IG_PASSWORD=

# ─── Budget Control ──────────────────────────────────────────────
MIN_BUDGET=50
TARGET_BUDGET=100
MAX_BUDGET=150

# ─── Safety / Rate Limiting ──────────────────────────────────────
DM_DAILY_LIMIT=30
DM_DELAY_MIN_SEC=60
DM_DELAY_MAX_SEC=90

# ─── Redis & Database ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres.atsepfvcsdzjsqjuhbym:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ─── Server ──────────────────────────────────────────────────────
PORT=3000

# ─── Meta Webhook (Instagram Graph API) ──────────────────────────
META_VERIFY_TOKEN=clawbot_secret_token_123

# ─── WhatsApp (Meta WhatsApp Cloud API) ──────────────────────────
# WhatsApp product on the same (or a separate) Meta app as Instagram.
# WhatsApp > API Setup: permanent token + phone number ID.
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Any string you choose; must match the verify token set in
# WhatsApp > Configuration > Webhook in the Meta dashboard.
WHATSAPP_VERIFY_TOKEN=clawbot_secret_token_123
# Comma-separated wa_ids (E.164 without '+') allowed to control the bot
WHATSAPP_CONTROL_NUMBERS=919905251524

# ─── LinkedIn → Email Outreach (free pipeline) ───────────────────
# See LINKEDIN_EMAIL_SETUP.md for the full walkthrough.
# Comma-separated LinkedIn search keywords to discover prospects
LINKEDIN_SEARCH_KEYWORDS=founder,marketing manager,content creator
# Max profiles to discover per run
LINKEDIN_DISCOVERY_MAX_PER_RUN=15
# How often the discovery job runs, in hours
LINKEDIN_SYNC_INTERVAL_HOURS=6

# ─── Google Workspace SMTP (sends the outreach email) ────────────
# Mailbox on your custom domain, e.g. outreach@makeable.nyc
GMAIL_USER=
# App Password generated from that mailbox's Google Account > Security
# (requires 2-Step Verification enabled) — NOT your login password
GMAIL_APP_PASSWORD=
# Max outreach emails sent per rolling 24h
EMAIL_DAILY_LIMIT=30
