{
  "manifest_version": 3,
  "name": "ClawBot Instagram Sync",
  "version": "1.0",
  "description": "Automatically syncs specific Instagram session cookies to your ClawBot server.",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClawBot Sync"
  }
}
