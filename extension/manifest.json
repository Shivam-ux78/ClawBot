{
  "manifest_version": 3,
  "name": "ClawBot Sync",
  "version": "1.1",
  "description": "Automatically syncs Instagram and LinkedIn session cookies to your ClawBot server.",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.linkedin.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClawBot Sync"
  }
}
